{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sitepack.org/schemas/site-map.schema.json",
  "title": "SitePack Site Map",
  "type": "object",
  "required": ["kind", "site", "pages"],
  "properties": {
    "kind": { "const": "site-map" },
    "site": {
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string" },
        "defaultLocale": { "type": "string", "minLength": 1 },
        "locales": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "meta": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "pages": {
      "type": "array",
      "items": { "$ref": "#/$defs/page" }
    },
    "menus": {
      "type": "array",
      "items": { "$ref": "#/$defs/menu" }
    },
    "redirects": {
      "type": "array",
      "items": { "$ref": "#/$defs/redirect" }
    },
    "annotations": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["id", "path", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "parentId": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "canonicalUrl": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "sort": { "type": "integer" },
        "showInMenu": { "type": "boolean" },
        "entityRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/link" }
        },
        "assetRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/link" }
        },
        "snapshotRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/link" }
        },
        "meta": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "menu": {
      "type": "object",
      "required": ["id", "title", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "locale": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/menuItem" }
        }
      },
      "additionalProperties": true
    },
    "menuItem": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "pageId": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/menuItem" }
        }
      },
      "additionalProperties": true
    },
    "redirect": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "status": { "type": "integer", "enum": [301, 302, 307, 308] }
      },
      "additionalProperties": true
    },
    "link": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["ref"],
          "properties": {
            "ref": { "type": "string", "minLength": 1 },
            "meta": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": true
}
